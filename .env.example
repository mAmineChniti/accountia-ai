# ============================================
# Accountia AI Accountant - Environment Variables
# ============================================
# All settings can be configured via environment variables
# pydantic-settings automatically reads these (case-insensitive)
# ============================================

# --------------------------------------------
# API Settings
# --------------------------------------------
APP_NAME=Accountia AI Accountant
VERSION=1.0.0
PORT=8000
HOST=0.0.0.0
DEBUG=false

# --------------------------------------------
# MongoDB (required)
# URI includes platform database name
# Format: mongodb://username:password@host:port/database
# --------------------------------------------
MONGO_URI=mongodb://localhost:27017/accountia_platform

# --------------------------------------------
# Redis (optional - for caching/task queue)
# --------------------------------------------
REDIS_URL=redis://localhost:6379/0

# --------------------------------------------
# AI Model Settings
# --------------------------------------------
# Base model for inference (HuggingFace model ID)
BASE_MODEL=Qwen/Qwen2.5-1.5B-Instruct

# Whether to use fine-tuned adapter (requires training first)
USE_FINE_TUNED=false

# Path to fine-tuned LoRA adapter (if USE_FINE_TUNED=true)
FINE_TUNED_MODEL_PATH=./models/accountant-lora

# Device for inference: auto, cpu, cuda, mps
DEVICE=auto

# Use 8-bit quantization to save VRAM (recommended for 4GB GPUs)
LOAD_IN_8BIT=true

# --------------------------------------------
# Groq API (fallback when local model not available)
# Get API key from: https://console.groq.com
# --------------------------------------------
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=4096
GROQ_TIMEOUT=120

# --------------------------------------------
# Processing Limits
# --------------------------------------------
MAX_PERIOD_DAYS=365
BATCH_SIZE=100

# --------------------------------------------
# Security (REQUIRED)
# --------------------------------------------
# API Key for service-to-service authentication
# Only Accountia API should have this key
# Generate a strong random key: openssl rand -hex 32
API_KEY=your_strong_api_key_here

# JWT Secret (optional, for additional JWT validation)
JWT_SECRET=your_jwt_secret_for_nestjs_integration
