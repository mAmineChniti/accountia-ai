# ============================================
# Accountia AI Accountant - Environment Variables (example)
# Copy this file to `.env` and fill in real secrets locally.
# DO NOT commit your `.env` file or secrets to source control.
# ============================================

# ----------------------
# API / App
# ----------------------
APP_NAME="Accountia AI Accountant"
VERSION=1.0.0
PORT=8000
HOST=0.0.0.0
DEBUG=false

# ----------------------
# MongoDB (required)
# URI should include the platform database name
# e.g.: mongodb://username:password@host:27017/accountia_platform
# ----------------------
MONGO_URI="mongodb://<username>:<password>@<host>:27017/accountia_platform"

# ----------------------
# Redis (optional - caching / task queue)
# ----------------------
REDIS_URL="redis://<user>:<pass>@<host>:6379/0"

# ----------------------
# AI Model Settings
# ----------------------
# HuggingFace model id or local path
BASE_MODEL="Qwen/Qwen2.5-1.5B-Instruct"
USE_FINE_TUNED=false
FINE_TUNED_MODEL_PATH="./models/accountant-lora"
DEVICE=auto
LOAD_IN_8BIT=true

# ----------------------
# Groq API (optional fallback)
# ----------------------
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"
GROQ_MAX_TOKENS=4096
GROQ_TIMEOUT=120

# ----------------------
# Processing / Performance
# ----------------------
MAX_PERIOD_DAYS=365
BATCH_SIZE=100
# When true, created jobs are enqueued to Redis and require workers
# (scripts/worker.py) to be running to process them.
USE_TASK_QUEUE=false

# ----------------------
# Security (REQUIRED)
# ----------------------
# Generate a strong random key for API access:
#   openssl rand -hex 32
API_KEY="your_service_api_key_here"

# JWT secret (optional)
JWT_SECRET="your_jwt_secret_here"

# ----------------------
# Notes
# - Copy this template to `.env` and populate secrets before running.
# - Keep `.env` out of git and rotate any credentials accidentally committed.
# - For production consider using a secrets manager (AWS Secrets Manager,
#   HashiCorp Vault, etc.) instead of a plain .env file.

